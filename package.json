{
  "name": "onibus-express",
  "version": "1.0.0",
  "description": "OniBus Express - Sistema de Venda de Passagens Rodoviárias.",
  "main": "index.js",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "dotnet run --project backend/OnibusExpress.Api --urls \"http://0.0.0.0:5000\"",
    "dev": "concurrently -n \"NET-API,VITE-APP\" -c \"cyan,green\" \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "dotnet build backend/OnibusExpress.Api",
    "build": "pnpm build:backend && pnpm build:frontend",
    "test:frontend": "pnpm --filter frontend test",
    "test:frontend:ci": "pnpm --filter frontend test:ci",
    "test:e2e": "pnpm --filter frontend test:e2e",
    "test:e2e:ui": "pnpm --filter frontend test:e2e:ui",
    "test": "pnpm test:frontend && pnpm test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.1",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
